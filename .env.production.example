# ─── Production (copy to .env.production) ─────────────────────────
# Same-origin API proxy (see next.config.mjs rewrites) — cookies work on the frontend domain.
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_SITE_URL=https://learning.phynixeducation.com

# Next.js rewrite target (server-side only, not exposed to browser)
API_INTERNAL_URL=https://api.phynixeducation.com

# Socket.IO connects directly to the backend (not proxied)
NEXT_PUBLIC_WS_URL=wss://api.phynixeducation.com

# Home page & marketing
NEXT_PUBLIC_HERO_IMAGE_URL=
NEXT_PUBLIC_APP_PREVIEW_IMAGE_URL=
NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@phynixeducation

# App store links (leave empty until published)
NEXT_PUBLIC_APP_ANDROID_URL=
NEXT_PUBLIC_APP_IOS_URL=

# Social media
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/phynixeducation
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/phynixeducation
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/phynixeducation
NEXT_PUBLIC_TWITTER_URL=https://x.com/phynixeducation
