# Same-origin API proxy (see next.config.mjs rewrites) — cookies work on the frontend domain.
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Next.js rewrite target (server-side only, not exposed to browser)
API_INTERNAL_URL=http://127.0.0.1:4000

# Socket.IO connects directly to the backend (not proxied)
NEXT_PUBLIC_WS_URL=http://localhost:4000

# Home page & marketing
NEXT_PUBLIC_HERO_IMAGE_URL=
NEXT_PUBLIC_APP_PREVIEW_IMAGE_URL=
NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@ieltslms

# App store links (leave empty until published)
NEXT_PUBLIC_APP_ANDROID_URL=
NEXT_PUBLIC_APP_IOS_URL=

# Social media
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_TWITTER_URL=
